# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Groq AI Configuration
# Get your free API key from: https://console.groq.com/keys
EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key

# Resend Email Configuration
# Sign up at: https://resend.com/ (Free tier: 3,000 emails/month)
EXPO_PUBLIC_RESEND_API_KEY=your_resend_api_key
EXPO_PUBLIC_FROM_EMAIL=your_verified_email@domain.com
EXPO_PUBLIC_FROM_NAME=MY INTERVIEW

# Adzuna Job Search API
# Sign up for free at: https://developer.adzuna.com/
EXPO_PUBLIC_ADZUNA_APP_ID=your_adzuna_app_id
EXPO_PUBLIC_ADZUNA_APP_KEY=your_adzuna_app_key

# RevenueCat Configuration
# Get from: https://app.revenuecat.com (test keys for development)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_revenuecat_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your_revenuecat_android_key

# Google Analytics Configuration
# Get from: https://analytics.google.com/ (Create a Google Analytics 4 property)
# For Universal Analytics (GA3), use format: UA-XXXXXXXXX-X
# For GA4, use format: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
